# Docker bind address and dashboard ports.
# Change these values to match your own environment.
BIND_HOST=0.0.0.0
QUOTA_DASHBOARD_PORT=18081
QUOTA_DASHBOARD_INTERNAL_PORT=8081

# sub2api Postgres connection.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sub2api

# Required: the sub2api base URL reachable from the quota dashboard container.
# Examples:
# - http://sub2api:8080
# - http://host.docker.internal:18080
# - http://192.168.1.10:18080
QUOTA_DASHBOARD_SUB2API_BASE_URL=http://sub2api:8080

# Required if you want scheduled automatic usage refresh.
QUOTA_DASHBOARD_ADMIN_EMAIL=admin@example.com
QUOTA_DASHBOARD_ADMIN_PASSWORD=change-me

# Required if you want to open the page directly with ?secret=...
QUOTA_DASHBOARD_TOKEN=change-me

# Optional: when set, the sidecar will sync a menu item into sub2api.
# Usually point this to your public dashboard URL including the secret.
QUOTA_DASHBOARD_PUBLIC_URL=
QUOTA_DASHBOARD_MENU_ID=account-quota-dashboard
QUOTA_DASHBOARD_MENU_LABEL=账号额度统计
QUOTA_DASHBOARD_MENU_VISIBILITY=admin

# Optional refresh tuning.
QUOTA_DASHBOARD_SNAPSHOT_INTERVAL_SECONDS=300
QUOTA_DASHBOARD_USAGE_REFRESH_INTERVAL_SECONDS=300
QUOTA_DASHBOARD_USAGE_REFRESH_BATCH_SIZE=1000
QUOTA_DASHBOARD_USAGE_REFRESH_TIMEOUT_SECONDS=15
